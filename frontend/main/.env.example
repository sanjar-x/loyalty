# Backend API (optional for debug-only mode)
BACKEND_API_BASE_URL=http://localhost:8000

# Telegram Bot (not needed when BROWSER_DEBUG_AUTH=true)
# TG_BOT_TOKEN=your_bot_token_here
# TG_INITDATA_MAX_AGE_SECONDS=300

# DaData (address suggestions)
DADATA_TOKEN=your_dadata_token
DADATA_SECRET=your_dadata_secret

# Cookie (leave empty for localhost)
COOKIE_DOMAIN=

# Debug auth (dev only — generates mock tokens without backend)
BROWSER_DEBUG_AUTH=true
NEXT_PUBLIC_BROWSER_DEBUG_AUTH=true
BROWSER_DEBUG_AUTH_ALLOWED_HOSTS=localhost
