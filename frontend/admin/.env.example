# ────────────────────────────────────────────────────────────────────────────
# Loyality Admin — environment variables
# Скопируй этот файл в .env.local и подставь значения.
# .env.local в .gitignore — никогда не коммить.
# ────────────────────────────────────────────────────────────────────────────

# Backend API (server-side only, через BFF — не прокидывать в браузер)
BACKEND_URL=http://127.0.0.1:8080

# Image Backend (server-side only)
IMAGE_BACKEND_URL=http://127.0.0.1:8080

# API-key для image-backend (server-side only — НЕ public!)
# Получи у DevOps или сгенерируй свой dev-ключ.
IMAGE_BACKEND_API_KEY=dev-api-key

# Базовый URL фронта (для генерации абсолютных ссылок, опционально)
FRONTEND_URL=http://localhost:3000
