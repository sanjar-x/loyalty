  "language": "Russian",
  "skipWebFetchPreflight": true,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoCompactWindow": 1000000,
  "fastMode": false,
  "promptSuggestionEnabled": true,
  "autoUpdatesChannel": "latest",
  "voiceEnabled": true,
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true
