# ==========================================
# Yandex Delivery
# ==========================================
# Bearer-токен берётся в личном кабинете Я.Доставки (раздел "Интеграция").
# Тестовая среда работает только по Москве (МСК).
# *_BASE_URL — документация; runtime читает host из constants.py по test_mode.
# PLATFORM_STATION_ID — дефолтный склад (точка А); если задан, используется
# как fallback, когда origin.metadata запроса не содержит свой station_id.
YANDEX_DELIVERY_BASE_URL=https://b2b-authproxy.taxi.yandex.net
YANDEX_DELIVERY_OAUTH_TOKEN=
YANDEX_DELIVERY_PLATFORM_STATION_ID=
YANDEX_DELIVERY_TEST_BASE_URL=https://b2b.taxi.tst.yandex.net
YANDEX_DELIVERY_TEST_OAUTH_TOKEN=y2_AgAAAAD04omrAAAPeAAAAAACRpC94Qk6Z5rUTgOcTgYFECJllXYKFx8
YANDEX_DELIVERY_TEST_PLATFORM_STATION_ID=fbed3aa1-2cc6-4370-ab4d-59c5cc9bb924

