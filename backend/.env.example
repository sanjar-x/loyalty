# ==========================================
# Application
# ==========================================
PROJECT_NAME=Enterprise API
VERSION=1.0.0
ENVIRONMENT=dev
DEBUG=True
SECRET_KEY=change-me-in-production

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# PostgreSQL
# ==========================================
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=enterprise

# ==========================================
# Redis
# ==========================================
REDISHOST=127.0.0.1
REDISPORT=6379
REDISUSER=default
REDISPASSWORD=password
REDISDATABASE=0

# ==========================================
# S3 / MinIO
# ==========================================
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_REGION=us-east-1
S3_BUCKET_NAME=enterprise-bucket
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/enterprise-bucket

# ==========================================
# RabbitMQ
# ==========================================
RABBITMQ_URL=amqp://admin:password@127.0.0.1:5672/
RABBITMQ_PRIVATE_URL=
# ==========================================
# Telegram Bot
# ==========================================
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BOT_ADMIN_IDS=[123456789]
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=
THROTTLE_RATE=0.5
FSM_STATE_TTL=
FSM_DATA_TTL=

# -- Telegram Mini App Auth ---
# TELEGRAM_INIT_DATA_MAX_AGE=300
# TELEGRAM_REFRESH_TOKEN_EXPIRE_DAYS=7
