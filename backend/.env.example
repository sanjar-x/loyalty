# ==========================================
# Application
# ==========================================
PROJECT_NAME=Enterprise API
VERSION=1.0.0
ENVIRONMENT=dev
DEBUG=True
SECRET_KEY=change-me-in-production

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# PostgreSQL
# ==========================================
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=enterprise

# ==========================================
# Redis
# ==========================================
REDISHOST=127.0.0.1
REDISPORT=6379
REDISUSER=default
REDISPASSWORD=password
REDISDATABASE=0

# ==========================================
# ImageBackend (server-to-server)
# ==========================================
IMAGE_BACKEND_URL=http://localhost:8080
IMAGE_BACKEND_API_KEY=

# ==========================================
# RabbitMQ
# ==========================================
RABBITMQ_URL=amqp://admin:password@127.0.0.1:5672/
RABBITMQ_PRIVATE_URL=
# ==========================================
# Telegram Bot
# ==========================================
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BOT_ADMIN_IDS=[123456789]
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=
THROTTLE_RATE=0.5
FSM_STATE_TTL=
FSM_DATA_TTL=

