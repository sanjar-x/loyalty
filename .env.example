# ==========================================
# Application
# ==========================================
PROJECT_NAME=Enterprise API
VERSION=1.0.0
ENVIRONMENT=dev
DEBUG=True
SECRET_KEY=change-me-in-production

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# PostgreSQL
# ==========================================
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=enterprise

# ==========================================
# Redis
# ==========================================
REDISHOST=127.0.0.1
REDISPORT=6379
REDISUSER=default
REDISPASSWORD=password
REDISDATABASE=0

# ==========================================
# S3 / MinIO
# ==========================================
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password
S3_REGION=us-east-1
S3_BUCKET_NAME=enterprise-bucket
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/enterprise-bucket

# ==========================================
# RabbitMQ
# ==========================================
RABBITMQ_URL=amqp://admin:password@127.0.0.1:5672/
